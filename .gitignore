# ============================================================
# Dependencies
# ============================================================
node_modules/
**/node_modules/

# ============================================================
# Environment & secrets — never commit these
# ============================================================
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ============================================================
# Build output
# ============================================================
dist/
build/
out/
**/dist/
**/build/
**/out/

# Vite cache
.vite/
**/.vite/

# TypeScript build info
*.tsbuildinfo
**/*.tsbuildinfo

# ============================================================
# Local data (crawler DB, embeddings cache)
# ============================================================
data/
**/data/
!data/.gitkeep

# ============================================================
# Logs
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
**/logs/

# ============================================================
# Test / coverage
# ============================================================
coverage/
.nyc_output/
**/coverage/

# ============================================================
# Playwright / browsers
# ============================================================
# Playwright writes these when `npx playwright install` runs
ms-playwright/
test-results/
playwright-report/
playwright/.cache/

# ============================================================
# Editor / OS
# ============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# ============================================================
# Misc
# ============================================================
.cache/
.parcel-cache/
.eslintcache
