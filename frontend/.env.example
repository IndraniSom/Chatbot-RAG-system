# Next.js public env vars (must be prefixed with NEXT_PUBLIC_ to be exposed to the browser)

# Backend API base URL. In dev, leave unset and the app calls /api/* via Next rewrite
# (configured in next.config.mjs). Set this when the frontend is deployed separately
# from the backend.
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_API_URL=
