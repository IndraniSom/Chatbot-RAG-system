# ============================================================
# Scrappy AI — Backend configuration
# ============================================================
# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed for reference.

# ----- Server -----
# Port the Express server listens on
PORT=5000
NODE_ENV=development

# ----- Qdrant Cloud (vector database) -----
# 1. Create a free cluster at https://cloud.qdrant.io
# 2. Copy the cluster URL from the dashboard
# 3. Create an API key and paste it below
QDRANT_URL=https://YOUR-CLUSTER-ID.us-west-X-0.aws.cloud.qdrant.io
QDRANT_API_KEY=replace-with-your-qdrant-api-key
# Name of the collection that stores embedded website chunks
QDRANT_COLLECTION=scrappy_knowledge

# ----- NVIDIA NIM (embeddings + chat) -----
# 1. Get an API key at https://build.nvidia.com
# 2. Paste it below
NVIDIA_API_KEY=nvapi-replace-with-your-nvidia-api-key

# Embedding model — used to vectorize website chunks and user queries
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_EMBEDDING_URL=https://integrate.api.nvidia.com/v1/embeddings

# Chat model — used to generate grounded answers in /api/chat
NVIDIA_LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# ----- Cloudinary (logo uploads) -----
# All three vars are required for logo uploads. Color customization
# works without them; missing Cloudinary config causes the upload
# endpoints to return 503 until configured.
# 1. Create a free account at https://cloudinary.com
# 2. From the dashboard, copy Cloud name and the API key + API secret
#    (the "Settings" → "API Keys" page). The API secret stays server-side.
#
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional folder root for uploaded widget logos
CLOUDINARY_FOLDER=scrappy-widget-logos
